# ==============================================================================
# MathBattle Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and update the values for local development.
# DO NOT commit the '.env' file or any real secrets to version control.

# ------------------------------------------------------------------------------
# 1. Database and Caching
# ------------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mathbattle?schema=public

# Redis connection string for caching, rate limiting, and BullMQ
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# 2. Server Ports and Environments
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
WS_PORT=3001

# ------------------------------------------------------------------------------
# 3. Security and Authentication (RS256 JWT Keys)
# ------------------------------------------------------------------------------
# Access and Refresh tokens lifetimes
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Base64-encoded RS256 private and public keys.
# Generate these locally using openssl.
JWT_PRIVATE_KEY=your_rs256_private_key_base64_encoded
JWT_PUBLIC_KEY=your_rs256_public_key_base64_encoded

# ------------------------------------------------------------------------------
# 4. AI Engine Configuration
# ------------------------------------------------------------------------------
# Supported providers: mock, openai, anthropic
AI_PROVIDER=mock
AI_PROVIDER_API_KEY=your_ai_api_key_here
AI_MODEL_NAME=gpt-4-turbo

# ------------------------------------------------------------------------------
# 5. External Integrations
# ------------------------------------------------------------------------------
# Transactional Email (SendGrid / Postmark)
EMAIL_SERVICE_API_KEY=your_email_api_key_here
EMAIL_FROM_ADDRESS=noreply@mathbattle.io

# Cloud Storage (AWS S3 / Google Cloud Storage)
STORAGE_BUCKET_NAME=mathbattle-assets
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=your_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
